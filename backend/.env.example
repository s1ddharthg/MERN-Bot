# MongoDB connection string (Atlas or local)
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/chatbox

# Long random string used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=

# Long random string used to sign cookies — generate with: openssl rand -hex 32
COOKIE_SECRET=

# OpenAI API key (https://platform.openai.com/api-keys)
OPEN_AI_SECRET=

# Optional: only set if your OpenAI account belongs to an organization
OPENAI_ORGANIZATION_ID=

# Port the backend listens on (most hosts inject this automatically)
PORT=5000

# Full URL of the deployed frontend, used for CORS. Omit/leave blank for local dev.
CLIENT_ORIGIN=http://localhost:5173

# Cookie domain. Omit for local dev. In production set to your API's domain
# (or leave unset if frontend and backend share the same parent domain).
COOKIE_DOMAIN=

# development | production — controls cookie secure/sameSite flags, morgan logging, etc.
NODE_ENV=development
